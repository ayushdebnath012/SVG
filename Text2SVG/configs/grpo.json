{
  "train_steps": 120,
  "batch_size": 2,
  "rollouts_per_caption": 4,
  "learning_rate": 1e-5,
  "lr_decay": 0.95,
  "lr_decay_every_steps": 20,
  "weight_decay": 1e-2,
  "max_grad_norm": 1.0,
  "clip_epsilon": 0.2,
  "kl_coefficient": 0.0,
  "warmup_steps": 5,
  "optimizer": "AdamW",
  "precision": "float16",
  "gradient_accumulation_steps": 4,
  "advantage_normalization": true,
  "log_every": 5,
  "save_every": 30,
  "dynamic_max_length": true,
  "dynamic_len_threshold": 200,
  "dynamic_len_min": 512,
  "dynamic_len_max": 2048,
  "chars_per_token": 3.5
}

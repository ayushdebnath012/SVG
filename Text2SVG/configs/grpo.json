{
  "train_steps": 20,
  "batch_size": 2,
  "rollouts_per_caption": 2,
  "learning_rate": 2e-5,
  "lr_decay": 0.7,
  "lr_decay_every_steps": 40,
  "weight_decay": 1e-2,
  "max_grad_norm": 1.0,
  "clip_epsilon": 0.4,
  "kl_coefficient": 0.0,
  "warmup_steps": 0,
  "optimizer": "AdamW",
  "precision": "float16",
  "gradient_accumulation_steps": 1,
  "advantage_normalization": false,
  "log_every": 5,
  "save_every": 40,
  "dynamic_max_length": true,
  "dynamic_len_threshold": 200,
  "dynamic_len_min": 256,
  "dynamic_len_max": 768,
  "chars_per_token": 4.0
}

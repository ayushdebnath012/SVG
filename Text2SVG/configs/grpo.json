{
  "train_steps": 1000,
  "batch_size": 8,
  "rollouts_per_caption": 8,
  "learning_rate": 5e-6,
  "lr_decay": 0.97,
  "lr_decay_every_steps": 100,
  "weight_decay": 1e-2,
  "max_grad_norm": 1.0,
  "clip_epsilon": 0.2,
  "kl_coefficient": 0.0,
  "warmup_steps": 30,
  "optimizer": "AdamW",
  "precision": "bfloat16",
  "gradient_accumulation_steps": 1,
  "advantage_normalization": true,
  "log_every": 10,
  "save_every": 100,
  "dynamic_max_length": true,
  "dynamic_len_threshold": 200,
  "dynamic_len_min": 512,
  "dynamic_len_max": 2048,
  "chars_per_token": 3.5
}

        "---\n",
        "## 3. Run Full Pipeline"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 🚀 **Complete Pipeline Function**\n",
        "\n",
        "def run_pipeline(\n",
        "    prompt: str,\n",
        "    seed: int = None,\n",
        "    max_refinements: int = 3,\n",
        "    dino_threshold: float = 0.85\n",
        ") -> Dict[str, Any]:\n",
        "    \"\"\"Run the complete DiffuSVG pipeline.\"\"\"\n",
        "    \n",
        "    result = {\n",
        "        'prompt': prompt,\n",
        "        'seed': seed,\n",
        "        'diffusion_image': None,\n",
        "        'svg_code': None,\n",
        "        'rendered_image': None,\n",
        "        'metrics': {},\n",
        "        'refinement_iterations': 0,\n",
        "        'success': False,\n",
        "        'error': None,\n",
        "        'timings': {}\n",
        "    }\n",
        "    \n",
        "    try:\n",
        "        # Phase 1: Generate image\n",
        "        t0 = time.time()\n",
        "        diff_image = diffusion.generate(prompt, seed=seed)\n",
        "        result['diffusion_image'] = diff_image\n",
        "        result['timings']['diffusion'] = time.time() - t0\n",
        "        \n",
        "        # Phase 2: Generate SVG\n",
        "        t0 = time.time()\n",
        "        raw_svg = vlm.generate_svg(diff_image, prompt)\n",
        "        svg_code = SVGUtils.extract_svg(raw_svg)\n",
        "        \n",
        "        if svg_code is None:\n",
        "            svg_code = SVGUtils.repair_svg(raw_svg)\n",
        "        \n",
        "        result['timings']['vlm_initial'] = time.time() - t0\n",
        "        \n",
        "        # Phase 3: Refinement loop\n",
        "        t0 = time.time()\n",
        "        for iteration in range(max_refinements):\n",
        "            if not SVGUtils.validate_svg(svg_code):\n",
        "                svg_code = SVGUtils.repair_svg(svg_code)\n",
        "                if not SVGUtils.validate_svg(svg_code):\n",
        "                    break\n",
        "            \n",
        "            rendered = SVGUtils.render_svg(svg_code)\n",
        "            if rendered is None:\n",
        "                break\n",
        "            \n",
        "            # Check DINO similarity\n",
        "            dino_score = metrics_calc.dino_similarity(diff_image, rendered)\n",
        "            \n",
        "            if dino_score >= dino_threshold:\n",
        "                break\n",
        "            \n",
        "            # Refine\n",
        "            refined_raw = vlm.refine_svg(diff_image, rendered, svg_code)\n",
        "            refined_svg = SVGUtils.extract_svg(refined_raw)\n",
        "            \n",
        "            if refined_svg and SVGUtils.validate_svg(refined_svg):\n",
        "                svg_code = refined_svg\n",
        "            \n",
        "            result['refinement_iterations'] = iteration + 1\n",
        "        \n",
        "        result['timings']['refinement'] = time.time() - t0\n",
        "        result['svg_code'] = svg_code\n",
        "        \n",
        "        # Final metrics\n",
        "        if SVGUtils.validate_svg(svg_code):\n",
        "            result['rendered_image'] = SVGUtils.render_svg(svg_code)\n",
        "            result['metrics'] = metrics_calc.compute_all(svg_code, diff_image, prompt)\n",
        "            result['success'] = result['metrics']['valid']\n",
        "        \n",
        "    except Exception as e:\n",
        "        result['error'] = str(e)\n",
        "    \n",
        "    return result\n",
        "\n",
        "print(\"✅ Pipeline function ready\")"
      ]
    },

    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 📊 **Run Full Evaluation** (takes ~1-2 hours)\n",
        "\n",
        "# Run pipeline on all selected prompts\n",
        "all_results = []\n",
        "\n",
        "print(f\"Running evaluation on {len(selected_prompts)} prompts...\")\n",
        "print(f\"Estimated time: {len(selected_prompts) * 1.5:.0f} - {len(selected_prompts) * 3:.0f} minutes\\n\")\n",
        "\n",
        "for i, prompt in enumerate(tqdm(selected_prompts, desc=\"Generating SVGs\")):\n",
        "    result = run_pipeline(\n",
        "        prompt=prompt,\n",
        "        seed=42 + i,\n",
        "        max_refinements=MAX_REFINEMENT_ITERATIONS\n",
        "    )\n",
        "    all_results.append(result)\n",
        "    \n",
        "    # Progress update every 10\n",
        "    if (i + 1) % 10 == 0:\n",
        "        valid = sum(1 for r in all_results if r['success'])\n",
        "        avg_clip = np.mean([r['metrics']['clip_score'] for r in all_results if r['success']])\n",
        "        print(f\"\\n  Progress: {i+1}/{len(selected_prompts)} | Valid: {valid}/{i+1} | Avg CLIP: {avg_clip:.2f}\")\n",
        "\n",
        "print(\"\\n✅ Evaluation complete!\")"
      ]

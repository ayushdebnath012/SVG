        "#@title 📊 **Metrics Calculator**\n",
        "\n",
        "class MetricsCalculator:\n",
        "    \"\"\"Calculate CLIP, DINO, and other metrics.\"\"\"\n",
        "    \n",
        "    def __init__(self, device='cuda'):\n",
        "        self.device = device\n",
        "        \n",
        "        # Load CLIP\n",
        "        print(\"Loading CLIP model...\")\n",
        "        self.clip_model, _, self.clip_preprocess = open_clip.create_model_and_transforms(\n",
        "            'ViT-B-32', pretrained='openai'\n",
        "        )\n",
        "        self.clip_model = self.clip_model.to(device).eval()\n",
        "        self.tokenizer = open_clip.get_tokenizer('ViT-B-32')\n",
        "        \n",
        "        # Load DINO\n",
        "        print(\"Loading DINO model...\")\n",
        "        self.dino_model = torch.hub.load('facebookresearch/dinov2', 'dinov2_vits14', verbose=False)\n",
        "        self.dino_model = self.dino_model.to(device).eval()\n",
        "        \n",
        "        print(\"✅ Metrics models loaded\")\n",
        "    \n",
        "    @torch.no_grad()\n",
        "    def clip_score(self, image: Image.Image, text: str) -> float:\n",
        "        \"\"\"Compute CLIP similarity (0-100 scale).\"\"\"\n",
        "        image_tensor = self.clip_preprocess(image).unsqueeze(0).to(self.device)\n",
        "        text_tokens = self.tokenizer([text]).to(self.device)\n",
        "        \n",
        "        image_features = self.clip_model.encode_image(image_tensor)\n",
        "        text_features = self.clip_model.encode_text(text_tokens)\n",
        "        \n",
        "        image_features = F.normalize(image_features, dim=-1)\n",
        "        text_features = F.normalize(text_features, dim=-1)\n",
        "        \n",
        "        similarity = (image_features @ text_features.T).item()\n",
        "        return similarity * 100  # Scale to 0-100\n",
        "    \n",
        "    @torch.no_grad()\n",
        "    def dino_similarity(self, image1: Image.Image, image2: Image.Image) -> float:\n",
        "        \"\"\"Compute DINO feature similarity (0-1 scale).\"\"\"\n",
        "        def preprocess(img):\n",
        "            img = img.resize((224, 224))\n",
        "            arr = np.array(img).astype(np.float32) / 255.0\n",
        "            arr = (arr - np.array([0.485, 0.456, 0.406])) / np.array([0.229, 0.224, 0.225])\n",
        "            return torch.from_numpy(arr).permute(2, 0, 1).unsqueeze(0).float().to(self.device)\n",
        "        \n",
        "        t1 = preprocess(image1)\n",
        "        t2 = preprocess(image2)\n",
        "        \n",
        "        f1 = self.dino_model(t1)\n",
        "        f2 = self.dino_model(t2)\n",
        "        \n",
        "        similarity = F.cosine_similarity(f1, f2).item()\n",
        "        return max(0, similarity)  # Clamp to positive\n",
        "    \n",
        "    def compute_all(self, svg_code: str, reference_image: Image.Image, prompt: str) -> Dict[str, Any]:\n",
        "        \"\"\"Compute all metrics for an SVG.\"\"\"\n",
        "        result = {\n",
        "            'valid': False,\n",
        "            'clip_score': 0.0,\n",
        "            'dino_score': 0.0,\n",
        "            'element_count': 0,\n",
        "            'path_count': 0,\n",
        "        }\n",
        "        \n",
        "        if not SVGUtils.validate_svg(svg_code):\n",
        "            return result\n",
        "        \n",
        "        rendered = SVGUtils.render_svg(svg_code)\n",
        "        if rendered is None:\n",
        "            return result\n",
        "        \n",
        "        result['valid'] = True\n",
        "        result['clip_score'] = self.clip_score(rendered, prompt)\n",
        "        result['dino_score'] = self.dino_similarity(reference_image, rendered)\n",
        "        \n",
        "        counts = SVGUtils.count_elements(svg_code)\n",
        "        result['element_count'] = counts['total']\n",
        "        result['path_count'] = counts['path']\n",
        "        \n",
        "        return result\n",
        "\n",
        "# Initialize metrics calculator\n",
        "metrics_calc = MetricsCalculator()"
      ]
    },
    {

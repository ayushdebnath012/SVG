        "#@title 🎨 **Diffusion Model Loader**\n",
        "\n",
        "class DiffusionGenerator:\n",
        "    \"\"\"SDXL-based image generator with optional LoRA.\"\"\"\n",
        "    \n",
        "    STYLE_PREFIX = \"flat vector illustration, clean edges, solid colors, simple shapes, minimal gradients, \"\n",
        "    NEGATIVE_PROMPT = \"gradient, photorealistic, blurry, complex textures, shadows, 3d render, realistic, detailed, intricate\"\n",
        "    \n",
        "    def __init__(self, use_lora: bool = False, lora_path: str = None):\n",
        "        print(\"Loading SDXL model (this takes ~2 minutes)...\")\n",
        "        \n",
        "        self.pipe = StableDiffusionXLPipeline.from_pretrained(\n",
        "            \"stabilityai/stable-diffusion-xl-base-1.0\",\n",
        "            torch_dtype=torch.float16,\n",
        "            use_safetensors=True,\n",
        "            variant=\"fp16\"\n",
        "        )\n",
        "        \n",
        "        self.pipe.scheduler = DPMSolverMultistepScheduler.from_config(\n",
        "            self.pipe.scheduler.config\n",
        "        )\n",
        "        \n",
        "        self.pipe = self.pipe.to(\"cuda\")\n",
        "        self.pipe.enable_xformers_memory_efficient_attention()\n",
        "        \n",
        "        if use_lora and lora_path:\n",
        "            print(f\"Loading LoRA from {lora_path}...\")\n",
        "            self.pipe.load_lora_weights(lora_path)\n",
        "        \n",
        "        print(\"✅ Diffusion model loaded\")\n",
        "    \n",
        "    @torch.inference_mode()\n",
        "    def generate(self, prompt: str, seed: int = None, num_steps: int = 25) -> Image.Image:\n",
        "        \"\"\"Generate a vector-style image.\"\"\"\n",
        "        full_prompt = self.STYLE_PREFIX + prompt\n",
        "        \n",
        "        generator = None\n",
        "        if seed is not None:\n",
        "            generator = torch.Generator(\"cuda\").manual_seed(seed)\n",
        "        \n",
        "        result = self.pipe(\n",
        "            prompt=full_prompt,\n",
        "            negative_prompt=self.NEGATIVE_PROMPT,\n",
        "            num_inference_steps=num_steps,\n",
        "            guidance_scale=7.5,\n",
        "            generator=generator,\n",
        "            width=1024,\n",
        "            height=1024,\n",
        "        )\n",
        "        \n",
        "        return result.images[0]\n",
        "\n",
        "# Load diffusion model\n",
        "diffusion = DiffusionGenerator()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 🤖 **VLM Code Generator**\n",
        "\n",
        "class VLMCodeGenerator:\n",
        "    \"\"\"VLM-based SVG code generation.\"\"\"\n",
        "    \n",
        "    SYSTEM_PROMPT = \"\"\"You are an expert SVG code generator. When given an image, analyze its visual components and generate precise, valid SVG code.\n",
        "\n",
        "RULES:\n",
        "1. Use viewBox=\"0 0 200 200\" with xmlns=\"http://www.w3.org/2000/svg\"\n",
        "2. Coordinate system: (0,0) is top-left, (200,200) is bottom-right\n",
        "3. Use appropriate primitives: rect, circle, ellipse, polygon, path\n",
        "4. Use solid fill colors (hex codes like #FF0000)\n",
        "5. Order elements by z-index (background first, foreground last)\n",
        "6. Keep it simple - prefer basic shapes over complex paths\n",
        "\n",
        "OUTPUT: Only valid SVG code. Start with <svg and end with </svg>. No explanation.\"\"\"\n",
        "\n",
        "    REFINE_PROMPT = \"\"\"Compare original image (first) with current SVG render (second).\n",
        "Fix these issues in the SVG:\n",
        "- Missing elements\n",
        "- Wrong positions/sizes\n",
        "- Color mismatches\n",
        "\n",
        "Current SVG:\n",
        "{current_svg}\n",
        "\n",
        "Output ONLY the corrected SVG code.\"\"\"\n",
        "    \n",
        "    def __init__(self, provider: str = \"anthropic\"):\n",
        "        self.provider = provider\n",
        "        \n",
        "        if provider == \"anthropic\":\n",
        "            import anthropic\n",
        "            self.client = anthropic.Anthropic()\n",
        "            self.model = \"claude-sonnet-4-20250514\"\n",
        "        else:\n",
        "            import openai\n",
        "            self.client = openai.OpenAI()\n",
        "            self.model = \"gpt-4o\"\n",
        "        \n",
        "        print(f\"✅ VLM initialized ({provider}, {self.model})\")\n",
        "    \n",
        "    def _image_to_base64(self, image: Image.Image) -> str:\n",
        "        buffer = io.BytesIO()\n",
        "        image.save(buffer, format=\"PNG\")\n",
        "        return base64.b64encode(buffer.getvalue()).decode('utf-8')\n",
        "    \n",
        "    def generate_svg(self, image: Image.Image, prompt: str) -> str:\n",
        "        \"\"\"Generate SVG from image.\"\"\"\n",
        "        img_b64 = self._image_to_base64(image)\n",
        "        \n",
        "        if self.provider == \"anthropic\":\n",
        "            response = self.client.messages.create(\n",
        "                model=self.model,\n",
        "                max_tokens=4096,\n",
        "                system=self.SYSTEM_PROMPT,\n",
        "                messages=[{\n",
        "                    \"role\": \"user\",\n",
        "                    \"content\": [\n",
        "                        {\"type\": \"text\", \"text\": f\"Convert this image to SVG. The image shows: {prompt}\"},\n",
        "                        {\"type\": \"image\", \"source\": {\"type\": \"base64\", \"media_type\": \"image/png\", \"data\": img_b64}}\n",
        "                    ]\n",
        "                }]\n",
        "            )\n",
        "            return response.content[0].text\n",
        "        else:\n",
        "            response = self.client.chat.completions.create(\n",
        "                model=self.model,\n",
        "                max_tokens=4096,\n",
        "                messages=[\n",
        "                    {\"role\": \"system\", \"content\": self.SYSTEM_PROMPT},\n",
        "                    {\"role\": \"user\", \"content\": [\n",
        "                        {\"type\": \"text\", \"text\": f\"Convert this image to SVG. The image shows: {prompt}\"},\n",
        "                        {\"type\": \"image_url\", \"image_url\": {\"url\": f\"data:image/png;base64,{img_b64}\"}}\n",
        "                    ]}\n",
        "                ]\n",
        "            )\n",
        "            return response.choices[0].message.content\n",
        "    \n",
        "    def refine_svg(self, original: Image.Image, rendered: Image.Image, current_svg: str) -> str:\n",
        "        \"\"\"Refine SVG based on visual comparison.\"\"\"\n",
        "        orig_b64 = self._image_to_base64(original)\n",
        "        rend_b64 = self._image_to_base64(rendered)\n",
        "        \n",
        "        prompt = self.REFINE_PROMPT.format(current_svg=current_svg)\n",
        "        \n",
        "        if self.provider == \"anthropic\":\n",
        "            response = self.client.messages.create(\n",
        "                model=self.model,\n",
        "                max_tokens=4096,\n",
        "                messages=[{\n",
        "                    \"role\": \"user\",\n",
        "                    \"content\": [\n",
        "                        {\"type\": \"text\", \"text\": \"Original image:\"},\n",
        "                        {\"type\": \"image\", \"source\": {\"type\": \"base64\", \"media_type\": \"image/png\", \"data\": orig_b64}},\n",
        "                        {\"type\": \"text\", \"text\": \"Current SVG render:\"},\n",
        "                        {\"type\": \"image\", \"source\": {\"type\": \"base64\", \"media_type\": \"image/png\", \"data\": rend_b64}},\n",
        "                        {\"type\": \"text\", \"text\": prompt}\n",
        "                    ]\n",
        "                }]\n",
        "            )\n",
        "            return response.content[0].text\n",
        "        else:\n",
        "            response = self.client.chat.completions.create(\n",
        "                model=self.model,\n",
        "                max_tokens=4096,\n",
        "                messages=[{\n",
        "                    \"role\": \"user\",\n",
        "                    \"content\": [\n",
        "                        {\"type\": \"text\", \"text\": \"Original image:\"},\n",
        "                        {\"type\": \"image_url\", \"image_url\": {\"url\": f\"data:image/png;base64,{orig_b64}\"}},\n",
        "                        {\"type\": \"text\", \"text\": \"Current SVG render:\"},\n",
        "                        {\"type\": \"image_url\", \"image_url\": {\"url\": f\"data:image/png;base64,{rend_b64}\"}},\n",
        "                        {\"type\": \"text\", \"text\": prompt}\n",
        "                    ]\n",
        "                }]\n",
        "            )\n",
        "            return response.choices[0].message.content\n",
        "\n",
        "# Initialize VLM\n",
        "vlm = VLMCodeGenerator(provider=API_PROVIDER)"
      ]
